# App URL (for QR /t/[token] and redeem links; required in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public support/contact email shown by customer-facing help pages
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Admin and internal access
ADMIN_EMAIL_ALLOWLIST=admin@example.com
NEXT_PUBLIC_INTERNAL_BYPASS_EMAILS=
ADMIN_DEBUG_KEY=

# Optional Google Places integration for admin venue/location tools
GOOGLE_MAPS_API_KEY=

# Optional Redis-backed rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_PREFIX=luxnight

# Ticket redemption grace windows
REDEEM_EARLY_MINUTES=0
REDEEM_LATE_MINUTES=30
